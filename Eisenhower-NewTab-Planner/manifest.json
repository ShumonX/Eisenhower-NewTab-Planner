{
  "manifest_version": 3,
  "name": "Eisenhower Planner",
  "version": "1.0",
  "description": "A custom new tab page with the Eisenhower Matrix.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}